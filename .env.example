# ── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Your Supabase project URL (safe to expose in the browser)
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key — used by the browser client (safe to expose)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — server-only, never expose to the browser
# Used by API routes and scripts that need to bypass Row-Level Security
SUPABASE_SERVICE_ROLE_KEY=

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Found in: platform.openai.com → API Keys
# Used for: match scoring, one-liner/explanation generation, semantic search, criteria generation
# Model: gpt-4o-mini
OPENAI_API_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
# Full URL of the deployed app — used for auth callbacks and absolute links
# Development: http://localhost:3000
# Production:  https://your-project.vercel.app
NEXT_PUBLIC_APP_URL=
